{
  "manifest_version": 3,
  "name": "AI2Web - AI Readiness Checker",
  "version": "0.1.0",
  "description": "Check any website's AI2Web readiness. See its AI Readiness Score and how well AI agents can discover and use it.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Check this site's AI readiness",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["activeTab"],
  "host_permissions": ["https://validator.ai2web.dev/*"]
}
